{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "*": "allow",
    "edit": "ask",
    "git": "deny",
    "bash": {
      "*": "allow",
      "git *": "deny",
      "git add -A*": "deny",
      "git add .*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "*--force-with-lease*": "deny",
      "rm *": "deny",
      "git log *": "allow"
    }
  }
}
