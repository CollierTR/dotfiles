{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "*": "allow",
    "edit": "ask",
    "git": "deny",
    "bash": {
      "*": "allow",
      "git *": "deny",
      "git add -A*": "deny",
      "git add .*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "*--force-with-lease*": "deny",
      "rm *": "deny",
      "git log *": "allow"
    }
  },

  "mcp": {
    "todoist": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://ai.todoist.net/mcp"],
      "enabled": true,
      "environment": {
        "TODOIST_API_KEY": "{env:TODOIST_API_KEY}",
        "NODE_EXTRA_CA_CERTS": "/etc/ssl/certs/ca-certificates.crt"
      }
    }
  }
}
